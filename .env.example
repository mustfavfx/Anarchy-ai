# Anarchy AI Environment Configuration
# Copy this file to .env and fill in your values

# ─── Supabase Auth ──────────────────────────────────────────────────────────────
# Create a project at https://supabase.com → Project Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Replicate API (Server-Side ONLY) ──────────────────────────────────────────
# The Replicate API key is NEVER stored in the frontend.
# All Replicate calls go through the Supabase Edge Function "replicate-proxy"
# which injects the key server-side.
#
# Set it via Supabase CLI:
#   supabase secrets set REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# The webhook URL is auto-constructed from VITE_SUPABASE_URL.
# No additional configuration is needed.

# ─── Stripe (Server-Side ONLY) ─────────────────────────────────────────────────
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
#   supabase secrets set APP_URL=https://your-app.com

# ─── Telemetry / Sentry Crash Monitoring ───────────────────────────────────────
VITE_SENTRY_DSN=

# Anarchy AI Environment Configuration
# Copy this file to .env and fill in your values

# Replicate API Token (optional - can also be set in Settings)
# Get your token from: https://replicate.com/account/api-tokens
VITE_REPLICATE_API_TOKEN=your_replicate_api_token_here

# Example:
# VITE_REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase Auth
# Create a project at https://supabase.com
# Project Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Replicate Webhook (optional - auto-constructed from VITE_SUPABASE_URL if not set)
# Webhook URL for async prediction notifications
# This should be your deployed Supabase Edge Function URL
VITE_REPLICATE_WEBHOOK_URL=https://your-project-ref.supabase.co/functions/v1/replicate-webhook

# Or for local development with Supabase CLI:
# VITE_REPLICATE_WEBHOOK_URL=http://localhost:54321/functions/v1/replicate-webhook

# Stripe (set in Supabase Edge Function secrets, NOT here)
# STRIPE_SECRET_KEY=sk_live_...        → supabase secrets set STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...      → supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
# APP_URL=https://your-app.com         → supabase secrets set APP_URL=http://localhost:5173

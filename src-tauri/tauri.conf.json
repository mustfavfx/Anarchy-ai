{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Anarchy AI",
  "version": "0.0.0",
  "identifier": "com.anarchyai.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Anarchy AI",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "decorations": false,
        "transparent": false,
        "fullscreen": false,
        "maximized": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data: https:; connect-src 'self' https://api.replicate.com https://replicate.delivery https:;"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyQkU4NjI4MUIxRTgzODQKUldTRWd4NGJLSWErZ25zQU44bExXRy9VM3dSSS9hWjFmUHBuZ1dXbW1PQzIzb0IzZlhjNHJ2TDMK",
      "endpoints": [
        "https://github.com/mustfavfx/Anarchy7/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "createUpdaterArtifacts": true
  }
}

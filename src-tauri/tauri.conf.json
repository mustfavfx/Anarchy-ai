{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Anarchy AI",
  "version": "0.0.7",
  "identifier": "com.anarchyai.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Anarchy AI",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "decorations": false,
        "transparent": false,
        "fullscreen": false,
        "maximized": true,
        "visible": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' ipc: http://ipc.localhost tauri: https: http: ws: wss:",
        "img-src": "'self' data: blob: https: http:",
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self' 'unsafe-eval'",
        "font-src": "'self' data:",
        "frame-src": "'self'",
        "worker-src": "'self' blob:"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyQkU4NjI4MUIxRTgzODQKUldTRWd4NGJLSWErZ25zQU44bExXRy9VM3dSSS9hWjFmUHBuZ1dXbW1PQzIzb0IzZlhjNHJ2TDMK",
      "endpoints": [
        "https://github.com/mustfavfx/Anarchy-ai/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/ana-file.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "custom-hooks.nsh"
      }
    },
    "fileAssociations": [
      {
        "ext": [
          "ana"
        ],
        "name": "Anarchy AI Project",
        "description": "Anarchy AI Project File",
        "mimeType": "application/x-anarchy-project",
        "role": "Editor"
      }
    ],
    "createUpdaterArtifacts": true
  }
}
